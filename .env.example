# ── Database ────────────────────────────────────────────────
# For local development, SQLite is used (no setup needed).
# To switch to PostgreSQL, change this to:
# postgresql://user:password@localhost:5432/releasepilot
DATABASE_URL=sqlite:///./releasepilot.db

# ── AI Provider ─────────────────────────────────────────────
# Using Ollama (free, runs locally - zero cost)
# Make sure Ollama is running: `ollama serve`
# And the model is pulled: `ollama pull llama3`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama

# ── Slack (optional - leave blank to just log notifications) ─
# To get a real webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
# ── GitHub (optional - leave blank to use mock data) ────────
# Create a token at: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_REPO=skosarajugit/project-mediwatch

# ── App settings ────────────────────────────────────────────
APP_NAME=ReleasePilot
APP_ENV=development       # development | production
BACKEND_URL=http://localhost:8000
